{
    "name": "PullPkg Private Composer Packages",
    "homepage": "https://app.pullpkg.dev",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/iRajul/filament-shadcn-theme.git"
        }
    ],
    "require": {
        "irajul/filament-shadcn-theme": "*"
    },
    "archive": {
        "directory": "dist",
        "format": "zip",
        "skip-dev": true,
        "checksum": true,
        "override-dist-type": true
    },
    "output-html": false
}
